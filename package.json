{
  "name": "__SERVICE_KEBAB__-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server for __SERVICE_TITLE__ — CLI (stdio / streamable HTTP) and programmatic API",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/__SERVICE_KEBAB__-mcp.d.ts",
      "import": "./dist/__SERVICE_KEBAB__-mcp.js",
      "default": "./dist/__SERVICE_KEBAB__-mcp.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/__SERVICE_KEBAB__-mcp.js",
  "types": "./dist/__SERVICE_KEBAB__-mcp.d.ts",
  "bin": {
    "__SERVICE_KEBAB__-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun scripts/build.ts",
    "dev": "bun run --watch src/cli.ts --http",
    "lint": "biome check . --diagnostic-level error",
    "mcp": "bunx @modelcontextprotocol/inspector",
    "jam": "bunx @mcpjam/inspector@latest",
    "prepublishOnly": "bun run build",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit --incremental"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "envalid": "8.1.1",
    "ky": "1.14.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
